/* ===== 综合习惯打卡页面样式 ===== */

/* 头部概览 */
.header-card {
  margin-top: var(--spacing-lg);
  text-align: center;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-lg);
}

.header-icon {
  font-size: 32px;
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.header-stats {
  display: flex;
  justify-content: space-around;
}

.stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 24px;
  font-weight: 700;
  color: var(--primary-color);
}

.stat-block:last-child .stat-num {
  color: var(--purple-color);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

/* ===== Tab 栏 ===== */
.tab-bar {
  display: flex;
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: 4px;
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-sm);
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-xs);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
}

.tab-item.active {
  background: var(--primary-color);
  box-shadow: var(--shadow-sm);
}

.tab-item.active .tab-label {
  color: #fff;
  font-weight: 600;
}

.tab-icon {
  font-size: 20px;
}

.tab-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
}

.tab-badge-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #FF6B6B;
  position: absolute;
  top: 6px;
  right: 20%;
}

/* 今日打卡 */
.today-card {
  padding: var(--spacing-lg);
}

.checkin-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg) 0;
  cursor: pointer;
}

.checkin-row:active {
  opacity: 0.7;
}

.checkin-row.done {
  opacity: 0.7;
}

.checkin-left {
  flex: 1;
}

.checkin-time {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.checkin-label {
  font-size: var(--font-xs);
  color: var(--text-light);
  margin-top: 4px;
  display: block;
}

.checkin-right {
  flex-shrink: 0;
  margin-left: var(--spacing-md);
}

.checkin-done {
  font-size: var(--font-sm);
  color: var(--success-color);
  font-weight: 500;
}

.checkin-btn {
  font-size: var(--font-sm);
  color: var(--primary-color);
  font-weight: 500;
  background: rgba(46, 125, 91, 0.1);
  padding: 6px 14px;
  border-radius: 20px;
}

.checkin-divider {
  height: 1px;
  background: var(--border-color);
  margin: 0;
}

/* 小贴士 */
.tips-card {
  padding: var(--spacing-lg);
}

.tips-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-md);
}

.tip-item {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.8;
}

/* 日历 */
.calendar-card {
  padding: var(--spacing-lg);
}

.calendar-header {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.calendar-month {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.calendar-weekdays {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
  margin-bottom: var(--spacing-sm);
}

.weekday {
  text-align: center;
  font-size: var(--font-xs);
  color: var(--text-light);
  padding: 4px 0;
}

.calendar-days {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 4px;
}

.calendar-day {
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  position: relative;
  min-height: 44px;
}

.calendar-day.empty {
  visibility: hidden;
}

.calendar-day.today {
  background: rgba(46, 125, 91, 0.08);
  border: 1px solid var(--primary-color);
}

.day-num {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: 400;
}

.today .day-num {
  font-weight: 600;
  color: var(--primary-color);
}

.day-checkin-dots {
  display: flex;
  gap: 3px;
  margin-top: 2px;
}

.dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--border-color);
}

.dot.morning.active {
  background: #FFB74D;
}

.dot.evening.active {
  background: #9575CD;
}

.calendar-legend {
  display: flex;
  justify-content: center;
  gap: var(--spacing-xl);
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--border-color);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.legend-item .dot {
  width: 8px;
  height: 8px;
}

/* ===== 补剂进度 ===== */
.supp-progress-card {
  padding: var(--spacing-lg);
}

.supp-progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.supp-progress-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.supp-progress-num {
  font-size: 28px;
  font-weight: 700;
  color: var(--purple-color);
}

.supp-progress-bar-bg {
  height: 10px;
  background: var(--bg-color);
  border-radius: 5px;
  overflow: hidden;
  margin-bottom: var(--spacing-sm);
}

.supp-progress-bar {
  height: 100%;
  background: linear-gradient(to right, var(--purple-color), #CE93D8);
  border-radius: 5px;
  transition: width 0.5s ease;
}

.supp-progress-tip {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
}

/* 管理按钮 */
.supp-manage-bar {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.supp-manage-btn {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--card-bg);
  border-radius: var(--radius-md);
  font-size: var(--font-xs);
  color: var(--text-secondary);
  border: 1px solid var(--border-color);
  cursor: pointer;
}

.supp-manage-btn:active {
  opacity: 0.7;
}

/* 提醒横幅 */
.reminder-alert-card {
  background: linear-gradient(135deg, rgba(179, 157, 219, 0.15), var(--card-bg));
  border: 1px solid rgba(179, 157, 219, 0.3);
  padding: var(--spacing-md) var(--spacing-lg);
}

.reminder-alert-content {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.reminder-alert-icon {
  font-size: 24px;
  flex-shrink: 0;
}

.reminder-alert-text {
  flex: 1;
}

.reminder-alert-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.reminder-alert-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.reminder-alert-close {
  font-size: var(--font-lg);
  color: var(--text-light);
  padding: 4px;
  cursor: pointer;
}

/* 空状态 */
.empty-supp-card {
  text-align: center;
  padding: var(--spacing-xl);
}

.empty-supp-text {
  font-size: var(--font-sm);
  color: var(--text-light);
}

/* 补剂卡片 */
.supp-item-card {
  display: flex;
  align-items: center;
  cursor: pointer;
  transition: all 0.15s;
}

.supp-item-card:active {
  transform: scale(0.98);
  opacity: 0.85;
}

.supp-item-icon {
  width: 44px;
  height: 44px;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  border: 1.5px solid;
}

.supp-item-info {
  flex: 1;
}

.supp-item-name {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.supp-item-detail {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.supp-item-status {
  flex-shrink: 0;
  margin-left: var(--spacing-md);
}

.supp-taken-badge {
  font-size: var(--font-xs);
  color: var(--success-color);
  font-weight: 500;
  background: rgba(76, 175, 80, 0.1);
  padding: 4px 10px;
  border-radius: 20px;
}

.supp-untaken-badge {
  font-size: var(--font-xs);
  color: var(--purple-color);
  font-weight: 500;
  background: rgba(179, 157, 219, 0.1);
  padding: 4px 10px;
  border-radius: 20px;
}

/* ===== 弹窗：补剂管理 ===== */
.supp-manage-modal {
  max-height: 80vh;
  overflow-y: auto;
}

.supp-list-edit {
  padding-bottom: var(--spacing-md);
}

.supp-edit-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--border-color);
}

.supp-edit-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex: 1;
}

.supp-edit-icon {
  font-size: 22px;
}

.supp-edit-info {
  flex: 1;
}

.supp-edit-name {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.supp-edit-detail {
  font-size: 10px;
  color: var(--text-light);
  display: block;
}

.supp-edit-actions {
  display: flex;
  gap: var(--spacing-xs);
  flex-shrink: 0;
}

.supp-edit-btn {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 12px;
  background: var(--bg-color);
  color: var(--text-secondary);
  cursor: pointer;
}

.supp-edit-btn.active {
  background: rgba(46, 125, 91, 0.1);
  color: var(--primary-color);
}

.supp-edit-btn.edit {
  color: var(--primary-color);
}

.supp-edit-btn.delete {
  color: var(--danger-color);
}

.supp-add-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-lg);
  border: 1px dashed var(--border-color);
  border-radius: var(--radius-md);
  margin-top: var(--spacing-md);
  cursor: pointer;
}

.supp-add-row:active {
  opacity: 0.7;
}

.supp-add-icon {
  font-size: 20px;
  color: var(--primary-color);
  font-weight: 700;
}

.supp-add-text {
  font-size: var(--font-sm);
  color: var(--primary-color);
}

/* 编辑补剂表单 */
.edit-supp-section {
  padding: var(--spacing-md) 0;
}

.edit-supp-field {
  margin-bottom: var(--spacing-md);
}

.edit-supp-label {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
  display: block;
}

.edit-supp-input {
  width: 100%;
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-sm);
  font-size: var(--font-sm);
  color: var(--text-primary);
  box-sizing: border-box;
}

.icon-picker {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  margin-top: var(--spacing-xs);
}

.icon-option {
  font-size: 24px;
  padding: var(--spacing-xs);
  border-radius: var(--radius-sm);
  border: 2px solid transparent;
  cursor: pointer;
}

.icon-option.active {
  border-color: var(--purple-color);
  background: rgba(179, 157, 219, 0.1);
}

.edit-supp-actions {
  display: flex;
  gap: var(--spacing-md);
  justify-content: center;
  margin-top: var(--spacing-xl);
}

.edit-supp-actions .btn-outline,
.edit-supp-actions .btn-primary {
  min-width: 100px;
}

/* ===== 弹窗：提醒设置 ===== */
.reminder-modal {
  padding-bottom: calc(var(--spacing-xl) + env(safe-area-inset-bottom, 0));
}

.reminder-tip-text {
  font-size: var(--font-xs);
  color: var(--text-light);
  text-align: center;
  margin-bottom: var(--spacing-lg);
  line-height: 1.5;
}

.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--border-color);
}

.reminder-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.reminder-icon {
  font-size: 24px;
}

.reminder-info {
  display: flex;
  flex-direction: column;
}

.reminder-label {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
}

.reminder-time {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

.reminder-right {
  flex-shrink: 0;
}

.reminder-subscribe {
  text-align: center;
  padding: var(--spacing-lg);
  margin-top: var(--spacing-md);
  background: rgba(179, 157, 219, 0.08);
  border-radius: var(--radius-md);
  cursor: pointer;
  font-size: var(--font-sm);
  color: var(--purple-color);
}

.reminder-subscribe:active {
  opacity: 0.7;
}

/* 通用弹窗 */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.modal-overlay.hidden {
  display: none;
}

.modal-dialog {
  background: var(--card-bg);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  width: 100%;
  padding: var(--spacing-xl);
  max-height: 70vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-md);
  border-bottom: 1px solid var(--border-color);
}

.modal-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: var(--font-lg);
  color: var(--text-light);
  padding: 4px;
  cursor: pointer;
}

/* 卡片绿底变体 */
.card-green {
  background: linear-gradient(135deg, rgba(46, 125, 91, 0.06), var(--card-bg));
  border: 1px solid rgba(46, 125, 91, 0.15);
}
