/* ===== 药品认知专题页样式 ===== */

.page-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  background: var(--card-bg);
}

.back-btn {
  font-size: var(--font-sm);
  color: var(--primary-color);
  padding: var(--spacing-xs) var(--spacing-sm);
  cursor: pointer;
}

.page-title {
  flex: 1;
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  margin-right: 40px;
}

/* 激素等级表 */
.hormone-table {
  font-size: var(--font-xs);
}

.table-header {
  display: flex;
  background: rgba(46, 125, 91, 0.06);
  padding: var(--spacing-sm);
  border-radius: var(--radius-sm);
  font-weight: 600;
  color: var(--text-primary);
}

.table-row {
  display: flex;
  padding: var(--spacing-md) var(--spacing-sm);
  border-bottom: 1px solid var(--border-color);
  align-items: center;
}

.table-row:last-child {
  border-bottom: none;
}

.th, .td {
  text-align: center;
}

.th-level, .td-level { width: 18%; }
.th-class, .td-class { width: 12%; }
.th-example, .td-example { width: 45%; text-align: left; }
.th-risk, .td-risk { width: 25%; }

.td-level { color: var(--primary-color); font-weight: 600; }
.td-risk { color: var(--danger-color); font-size: 10px; }

/* 政府查询入口 */
.gov-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
}

.gov-content {
  display: flex;
  align-items: center;
}

.gov-icon {
  font-size: 28px;
  margin-right: var(--spacing-md);
}

.gov-title {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
}

.gov-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

.gov-arrow {
  color: var(--text-light);
}

/* 风险药膏 */
.risk-disclaimer {
  font-size: var(--font-xs);
  color: var(--text-light);
  padding: 0 var(--spacing-lg) var(--spacing-sm);
}

.risk-item {
  margin-bottom: var(--spacing-md);
}

.risk-name {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.risk-tag {
  margin-bottom: var(--spacing-xs);
}

.risk-detail {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  line-height: 1.5;
}

.drug-footer-disclaimer {
  margin: var(--spacing-xl) var(--spacing-lg);
  padding: var(--spacing-md);
  background: rgba(229, 115, 115, 0.06);
  border-radius: var(--radius-md);
  font-size: 10px;
  color: var(--text-light);
  line-height: 1.6;
}
