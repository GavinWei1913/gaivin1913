/* ===== 银屑助手 - 全局样式 ===== */

/* CSS 变量 */
page {
  --primary-color: #2E7D5B;
  --primary-light: #3E9D73;
  --primary-dark: #1F5E42;
  --purple-color: #B39DDB;
  --purple-light: #D1C4E9;
  --purple-dark: #9575CD;
  --bg-color: #F5F7FA;
  --card-bg: #FFFFFF;
  --text-primary: #1A1A2E;
  --text-secondary: #666680;
  --text-light: #9999AA;
  --border-color: #EEEEF0;
  --danger-color: #E57373;
  --warning-color: #FFB74D;
  --success-color: #81C784;
  --info-color: #64B5F6;
  --shadow-sm: 0 2px 8px rgba(0,0,0,0.04);
  --shadow-md: 0 4px 16px rgba(0,0,0,0.06);
  --shadow-lg: 0 8px 32px rgba(0,0,0,0.08);
  --radius-sm: 8px;
  --radius-md: 12px;
  --radius-lg: 16px;
  --radius-xl: 20px;
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 24px;
  --spacing-2xl: 32px;
  
  --font-xs: 11px;
  --font-sm: 13px;
  --font-md: 15px;
  --font-lg: 17px;
  --font-xl: 20px;
  --font-2xl: 24px;
  
  background-color: var(--bg-color);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 重置样式 */
view, text, scroll-view, swiper {
  box-sizing: border-box;
}

/* 卡片基础样式 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg);
  margin: 0 var(--spacing-lg) var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

.card-purple {
  background: linear-gradient(135deg, var(--purple-light), var(--card-bg));
  border: 1px solid rgba(179, 157, 219, 0.3);
}

.card-green {
  background: linear-gradient(135deg, rgba(46, 125, 91, 0.08), var(--card-bg));
  border: 1px solid rgba(46, 125, 91, 0.15);
}

/* 按钮基础样式 */
.btn-primary {
  background: var(--primary-color);
  color: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
  text-align: center;
  border: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary.block {
  display: flex;
  width: 100%;
}

.btn-outline {
  background: transparent;
  color: var(--primary-color);
  border: 1.5px solid var(--primary-color);
  border-radius: var(--radius-md);
  padding: var(--spacing-sm) var(--spacing-lg);
  font-size: var(--font-sm);
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.btn-purple {
  background: var(--purple-color);
  color: #fff;
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-xl);
  font-size: var(--font-md);
  text-align: center;
  border: none;
}

/* 标题样式 */
.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-md);
}

.section-subtitle {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding: 0 var(--spacing-lg) var(--spacing-md);
}

/* 搜索框 */
.search-box {
  margin: var(--spacing-lg);
  background: var(--card-bg);
  border-radius: var(--radius-xl);
  padding: var(--spacing-sm) var(--spacing-lg);
  display: flex;
  align-items: center;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--border-color);
}

.search-box .search-icon {
  width: 18px;
  height: 18px;
  margin-right: var(--spacing-sm);
  color: var(--text-light);
}

.search-box .search-input {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
  height: 36px;
  line-height: 36px;
  border: none;
  outline: none;
  background: transparent;
}

.search-box .search-input::placeholder {
  color: var(--text-light);
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 2px 10px;
  border-radius: 20px;
  font-size: var(--font-xs);
  margin-right: var(--spacing-xs);
}

.tag-green {
  background: rgba(46, 125, 91, 0.1);
  color: var(--primary-color);
}

.tag-purple {
  background: rgba(179, 157, 219, 0.15);
  color: var(--purple-dark);
}

.tag-orange {
  background: rgba(255, 183, 77, 0.2);
  color: #E65100;
}

.tag-red {
  background: rgba(229, 115, 115, 0.15);
  color: #C62828;
}

/* 横向滚动容器 */
.scroll-x {
  white-space: nowrap;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding: 0 var(--spacing-lg);
}

.scroll-x::-webkit-scrollbar {
  display: none;
}

.scroll-x-item {
  display: inline-block;
  margin-right: var(--spacing-md);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 20px;
}

.empty-state .empty-icon {
  font-size: 48px;
  margin-bottom: var(--spacing-lg);
}

.empty-state .empty-text {
  font-size: var(--font-sm);
  color: var(--text-light);
  text-align: center;
}

/* 分隔线 */
.divider {
  height: 1px;
  background: var(--border-color);
  margin: var(--spacing-lg);
}

/* 页面容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: 100px;
  background: var(--bg-color);
}

/* 加载动画 */
.loading-spinner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

/* 徽标 */
.badge-dot {
  display: inline-block;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--danger-color);
  margin-left: 4px;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  background: var(--card-bg);
  border-bottom: 1px solid var(--border-color);
}

.list-item:last-child {
  border-bottom: none;
}

/* 两列网格 */
.grid-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--spacing-md);
  padding: 0 var(--spacing-lg);
}

/* Toast 提示 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0,0,0,0.75);
  color: #fff;
  padding: 12px 24px;
  border-radius: var(--radius-md);
  font-size: var(--font-sm);
  z-index: 999;
  text-align: center;
  max-width: 80%;
}

/* 动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.3s ease-out;
}

/* 安全区 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom, 0);
}
