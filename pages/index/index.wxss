/* ===== 百科首页样式 ===== */

.header-placeholder {
  height: 20px;
}

/* 搜索区药字按钮 */
.drug-btn {
  width: 36px;
  height: 36px;
  background: rgba(46, 125, 91, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-sm);
  color: var(--primary-color);
  font-weight: 600;
  flex-shrink: 0;
  margin-left: var(--spacing-sm);
}

/* 药品知识卡片 - 横向滑动 */
.knowledge-scroll {
  padding-bottom: var(--spacing-sm);
}

.knowledge-card {
  width: 200px;
  min-height: 100px;
  margin-right: var(--spacing-md);
  white-space: normal;
  display: inline-flex;
  flex-direction: column;
  align-items: flex-start;
  padding: var(--spacing-lg);
  border: 1px solid var(--border-color);
}

.knowledge-card:active {
  opacity: 0.8;
}

.knowledge-icon {
  font-size: 28px;
  margin-bottom: var(--spacing-sm);
}

.knowledge-title {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
  line-height: 1.4;
}

.knowledge-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

/* 饮食引导卡片 */
.diet-card {
  cursor: pointer;
}

.diet-card:active {
  opacity: 0.85;
}

.diet-guide {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-md);
}

.diet-guide-icon {
  font-size: 36px;
  flex-shrink: 0;
}

.diet-guide-text {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
}

.diet-btn {
  width: 100%;
  text-align: center;
}

/* 饮食结果 */
.diet-result {
  width: 100%;
}

.diet-section {
  margin-bottom: var(--spacing-md);
}

.diet-section-title {
  font-size: var(--font-md);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.diet-item {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  padding: var(--spacing-xs) 0;
  padding-left: var(--spacing-lg);
  position: relative;
  line-height: 1.6;
}

.diet-item::before {
  content: '•';
  position: absolute;
  left: var(--spacing-sm);
  color: var(--primary-color);
}

.diet-avoid::before {
  color: var(--danger-color);
}

.diet-divider {
  height: 1px;
  background: var(--border-color);
  margin: var(--spacing-md) 0;
}

.diet-disclaimer {
  font-size: var(--font-xs);
  color: var(--text-light);
  margin-top: var(--spacing-sm);
  padding: var(--spacing-sm);
  background: rgba(179, 157, 219, 0.08);
  border-radius: var(--radius-sm);
}

/* 饮食速查Tab */
.diet-tabs-card {
  padding: var(--spacing-md);
}

.diet-tabs {
  display: flex;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: 3px;
  margin-bottom: var(--spacing-md);
}

.diet-tab {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm) 0;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  transition: all 0.2s;
}

.diet-tab.active {
  background: var(--card-bg);
  color: var(--primary-color);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

.food-item {
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--border-color);
}

.food-item:last-child {
  border-bottom: none;
}

.food-name {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: var(--spacing-xs);
}

.food-reason,
.food-nutrient {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.food-nutrient-tag {
  display: inline-block;
  margin-top: var(--spacing-xs);
  padding: 1px 8px;
  background: rgba(46, 125, 91, 0.08);
  border-radius: 10px;
  font-size: 10px;
  color: var(--primary-color);
}

/* 分类Tab */
.category-tabs {
  display: flex;
  padding-bottom: var(--spacing-sm);
}

.category-tab {
  display: inline-block;
  padding: var(--spacing-xs) var(--spacing-lg);
  margin-right: var(--spacing-sm);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  background: var(--card-bg);
  border-radius: 20px;
  border: 1px solid var(--border-color);
}

.category-tab.active {
  background: var(--primary-color);
  color: #fff;
  border-color: var(--primary-color);
}

/* 文章列表 */
.article-list {
  padding: 0 var(--spacing-lg);
}

.article-card {
  padding: 0;
  overflow: hidden;
  margin-bottom: var(--spacing-lg);
}

.article-card:active {
  opacity: 0.85;
}

.article-cover {
  width: 100%;
  height: 160px;
  display: block;
}

.article-content {
  padding: var(--spacing-lg);
}

.article-category {
  margin-bottom: var(--spacing-xs);
}

.article-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-sm);
  line-height: 1.4;
}

.article-summary {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--spacing-sm);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-meta {
  display: flex;
  align-items: center;
}

.article-reads {
  font-size: var(--font-xs);
  color: var(--text-light);
}
