/* ===== 健康报告样式 ===== */

.header-card {
  margin-top: var(--spacing-lg);
  text-align: center;
}

.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-sm);
}

.header-icon {
  font-size: 32px;
}

.header-title {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--text-primary);
}

.header-subtitle {
  font-size: var(--font-xs);
  color: var(--text-light);
  display: block;
  text-align: center;
}

/* 周期选择 */
.period-card {
  padding: var(--spacing-md);
}

.period-tabs {
  display: flex;
  background: var(--bg-color);
  border-radius: var(--radius-md);
  padding: 3px;
}

.period-tab {
  flex: 1;
  text-align: center;
  padding: var(--spacing-sm);
  font-size: var(--font-sm);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  cursor: pointer;
}

.period-tab.active {
  background: var(--card-bg);
  color: var(--primary-color);
  font-weight: 600;
  box-shadow: var(--shadow-sm);
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60px 20px;
}

.loading-spinner {
  font-size: 48px;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: var(--spacing-lg);
}

/* 报告内容 */
.report-content {
  padding-bottom: var(--spacing-lg);
}

.report-section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--spacing-lg);
}

/* 总览 */
.overview-report-card {
  text-align: center;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: var(--spacing-md);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md);
  background: var(--bg-color);
  border-radius: var(--radius-md);
}

.ov-num {
  font-size: 24px;
  font-weight: 700;
  color: var(--primary-color);
}

.overview-item:last-child .ov-num {
  color: var(--purple-color);
}

.ov-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

/* 趋势卡片 */
.trend-card {
  margin-bottom: var(--spacing-md);
}

.trend-text {
  font-size: var(--font-sm);
  font-weight: 500;
  display: block;
  margin-bottom: var(--spacing-md);
}

.trend-up { color: var(--success-color); }
.trend-down { color: var(--danger-color); }
.trend-stable { color: var(--text-secondary); }

/* 瘙痒柱状图 */
.trend-chart-simple {
  display: flex;
  align-items: flex-end;
  gap: 6px;
  height: 100px;
  padding-top: var(--spacing-md);
}

.trend-bar-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.trend-bar {
  width: 100%;
  max-width: 24px;
  background: linear-gradient(to top, var(--primary-color), var(--primary-light));
  border-radius: 4px 4px 0 0;
  min-height: 8px;
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  transition: height 0.3s;
}

.trend-bar-label {
  font-size: 9px;
  color: #fff;
  font-weight: 500;
  margin-top: 2px;
}

.trend-bar-date {
  font-size: 8px;
  color: var(--text-light);
  margin-top: 4px;
}

/* 皮损统计 */
.area-stats {
  display: flex;
  justify-content: space-around;
}

.area-stat-block {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.area-stat-num {
  font-size: 28px;
  font-weight: 700;
}

.area-stat-num.green { color: var(--success-color); }
.area-stat-num.red { color: var(--danger-color); }

.area-stat-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

/* 饮食进度条 */
.diet-rate-bar-bg {
  height: 12px;
  background: var(--bg-color);
  border-radius: 6px;
  overflow: hidden;
  margin-bottom: var(--spacing-sm);
}

.diet-rate-bar {
  height: 100%;
  background: linear-gradient(to right, var(--primary-color), var(--primary-light));
  border-radius: 6px;
  transition: width 0.5s;
}

.diet-rate-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  text-align: right;
}

/* 心情柱状图 */
.mood-chart-simple {
  display: flex;
  align-items: flex-end;
  gap: 6px;
  height: 80px;
  padding-top: var(--spacing-md);
}

.mood-bar-wrapper {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
  justify-content: flex-end;
}

.mood-bar {
  width: 100%;
  max-width: 32px;
  background: linear-gradient(to top, var(--purple-color), var(--purple-light));
  border-radius: 4px 4px 0 0;
  min-height: 10px;
  display: flex;
  align-items: flex-start;
  justify-content: center;
}

.mood-bar-emoji {
  font-size: 14px;
  margin-top: -18px;
}

.mood-bar-date {
  font-size: 8px;
  color: var(--text-light);
  margin-top: 4px;
}

/* 感染预警 */
.card-warning {
  background: linear-gradient(135deg, rgba(229, 115, 115, 0.08), var(--card-bg));
  border: 1px solid rgba(229, 115, 115, 0.2);
}

.warning-text {
  font-size: var(--font-sm);
  color: #C62828;
  line-height: 1.6;
}

/* 润肤打卡 */
.checkin-report {
  display: flex;
  justify-content: space-around;
}

.checkin-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.checkin-stat-num {
  font-size: 28px;
  font-weight: 700;
  color: var(--primary-color);
}

.checkin-stat-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

/* ===== 补剂依从性 ===== */
.supp-report-summary {
  text-align: center;
  margin-bottom: var(--spacing-lg);
}

.supp-report-rate {
  font-size: 32px;
  font-weight: 700;
  color: var(--purple-color);
  display: block;
}

.supp-report-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.supp-report-detail {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.supp-report-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.supp-report-item-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  width: 60px;
  flex-shrink: 0;
}

.supp-report-icon {
  font-size: 16px;
}

.supp-report-name {
  font-size: var(--font-xs);
  color: var(--text-primary);
  font-weight: 500;
}

.supp-report-item-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.supp-report-bar-bg {
  height: 8px;
  background: var(--bg-color);
  border-radius: 4px;
  overflow: hidden;
  width: 100%;
}

.supp-report-bar {
  height: 100%;
  background: linear-gradient(to right, var(--purple-color), #CE93D8);
  border-radius: 4px;
  transition: width 0.5s;
}

.supp-report-percent {
  font-size: 9px;
  color: var(--text-light);
  text-align: right;
}

.report-tip {
  margin-top: var(--spacing-md);
  font-size: var(--font-xs);
  color: var(--text-secondary);
  text-align: center;
  background: var(--bg-color);
  padding: var(--spacing-sm) var(--spacing-md);
  border-radius: var(--radius-sm);
}

/* PDF生成按钮 */
.generate-pdf-section {
  padding: var(--spacing-xl) var(--spacing-lg);
  text-align: center;
}

.generate-btn {
  margin-bottom: var(--spacing-sm);
}

.generate-tip {
  font-size: var(--font-xs);
  color: var(--text-light);
}

/* 无数据 */
.empty-state {
  padding: 60px 20px;
}

.go-record-btn {
  margin-top: var(--spacing-lg);
}
