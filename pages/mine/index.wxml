<!-- 我的 - 个人中心 -->
<view class="page-container">

  <!-- ===== 1. 个人状态 ===== -->
  <view class="card profile-card">
    <view class="profile-header">
      <view class="profile-avatar">
        <image src="{{avatarUrl || '/images/default_avatar.png'}}" mode="aspectFill" />
      </view>
      <view class="profile-info">
        <view class="profile-name">{{nickname}}</view>
        <view class="profile-days">已陪伴你管理银屑病 {{accompanyDays}} 天 🌿</view>
        <view class="profile-checkin-stats">
          <text class="checkin-streak">🔥 连续习惯打卡 {{checkInStreak}} 天</text>
          <text wx:if="{{suppRate > 0}}" class="supp-streak"> · 今日补剂 {{suppRate}}%</text>
        </view>
      </view>
      <view class="profile-edit" bindtap="editProfile">编辑</view>
    </view>
    
    <!-- 勋章墙 -->
    <view class="badge-wall">
      <view class="badge-item {{badges.hasRecord7 ? '' : 'disabled'}}">
        <text class="badge-icon">📝</text>
        <text class="badge-label">坚持记录7天</text>
      </view>
      <view class="badge-item {{badges.hasDietSurvey ? '' : 'disabled'}}">
        <text class="badge-icon">🥗</text>
        <text class="badge-label">完成饮食问卷</text>
      </view>
      <view class="badge-item {{badges.hasMoodDiary ? '' : 'disabled'}}">
        <text class="badge-icon">📓</text>
        <text class="badge-label">心情记录</text>
      </view>
      <view class="badge-item {{badges.hasPhoto ? '' : 'disabled'}}">
        <text class="badge-icon">📸</text>
        <text class="badge-label">皮损拍照</text>
      </view>
      <view class="badge-item {{badges.hasCheckIn7 ? '' : 'disabled'}}">
        <text class="badge-icon">🧴</text>
        <text class="badge-label">打卡7天</text>
      </view>
      <view class="badge-item {{badges.hasSuppCheckIn ? '' : 'disabled'}}">
        <text class="badge-icon">🧪</text>
        <text class="badge-label">补剂打卡</text>
      </view>
    </view>
  </view>

  <!-- ===== 今日习惯打卡快捷入口 ===== -->
  <view class="card checkin-quick-card" bindtap="goCheckIn">
    <view class="checkin-quick-left">
      <text class="checkin-quick-icon">🌿</text>
      <view class="checkin-quick-text">
        <text class="checkin-quick-title">日常习惯打卡</text>
        <text class="checkin-quick-status">
          {{checkInToday ? '✅ 今日已打卡 · 补剂' + suppRate + '%' : '今日尚未打卡'}}
        </text>
      </view>
    </view>
    <view class="checkin-quick-arrow">
      <text>去打卡 →</text>
    </view>
  </view>

  <!-- ===== 2. 功能菜单 ===== -->
  <view class="card menu-card">
    <view class="menu-item" bindtap="goHealthReport">
      <text class="menu-icon">📊</text>
      <text class="menu-text">我的健康报告</text>
      <text class="menu-tag tag tag-green">PDF</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goCheckIn">
      <text class="menu-icon">🌿</text>
      <text class="menu-text">日常习惯打卡</text>
      <text class="menu-tag tag tag-green">润肤+补剂</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goMedicalMemo">
      <text class="menu-icon">📋</text>
      <text class="menu-text">就医备忘</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goFavorites">
      <text class="menu-icon">📝</text>
      <text class="menu-text">我的收藏</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goFeedback">
      <text class="menu-icon">💬</text>
      <text class="menu-text">意见反馈</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="joinCommunity">
      <text class="menu-icon">👥</text>
      <text class="menu-text">加入抗银交流群</text>
      <text class="menu-tag tag tag-green">新</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <!-- ===== 3. 精选好物（商城预留） ===== -->
  <view class="section-title">🛒 皮肤与免疫支持好物</view>
  
  <view class="card shop-card">
    <view class="shop-item" wx:for="{{shopItems}}" wx:key="id" bindtap="goShop" data-url="{{item.url}}">
      <view class="shop-img">{{item.emoji}}</view>
      <view class="shop-info">
        <view class="shop-title">{{item.name}}</view>
        <view class="shop-desc">{{item.desc}}</view>
      </view>
      <view class="shop-tag">去购买 →</view>
    </view>
    <view class="shop-disclaimer">商品由合作品牌直供，银屑助手仅作优选推荐。</view>
  </view>

  <view class="safe-area-bottom"></view>
</view>
