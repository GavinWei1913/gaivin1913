/* ===== 我的页面样式 ===== */

.profile-card {
  margin-top: var(--spacing-lg);
}

.profile-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.profile-avatar {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  overflow: hidden;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
  background: var(--bg-color);
}

.profile-avatar image {
  width: 100%;
  height: 100%;
}

.profile-info {
  flex: 1;
}

.profile-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
}

.profile-days {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

.profile-checkin-stats {
  margin-top: 4px;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
}

.checkin-streak {
  font-size: 10px;
  color: var(--primary-color);
  font-weight: 500;
}

.supp-streak {
  font-size: 10px;
  color: var(--purple-color);
  font-weight: 500;
}

.profile-edit {
  font-size: var(--font-xs);
  color: var(--primary-color);
  padding: 4px 12px;
  border: 1px solid var(--primary-color);
  border-radius: 20px;
  cursor: pointer;
}

/* 勋章墙 */
.badge-wall {
  display: flex;
  gap: var(--spacing-sm);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--border-color);
  flex-wrap: wrap;
}

.badge-item {
  flex: 1;
  min-width: 52px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.badge-item.disabled {
  opacity: 0.35;
}

.badge-icon {
  font-size: 20px;
}

.badge-label {
  font-size: 7px;
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.2;
}

/* 润肤打卡快捷入口 */
.checkin-quick-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, rgba(46, 125, 91, 0.08), rgba(179, 157, 219, 0.08));
  border: 1px solid rgba(46, 125, 91, 0.15);
  cursor: pointer;
}

.checkin-quick-card:active {
  opacity: 0.8;
}

.checkin-quick-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.checkin-quick-icon {
  font-size: 28px;
}

.checkin-quick-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.checkin-quick-status {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  display: block;
  margin-top: 2px;
}

.checkin-quick-arrow {
  font-size: var(--font-sm);
  color: var(--primary-color);
  font-weight: 500;
}

/* 功能菜单 */
.menu-card {
  padding: 0;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--border-color);
  cursor: pointer;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: var(--bg-color);
}

.menu-icon {
  font-size: 22px;
  margin-right: var(--spacing-md);
  width: 28px;
  text-align: center;
}

.menu-text {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary);
}

.menu-tag {
  margin-right: var(--spacing-sm);
  font-size: 10px;
}

.menu-arrow {
  color: var(--text-light);
  font-size: var(--font-md);
}

/* 商城 */
.shop-card {
  padding: var(--spacing-md);
}

.shop-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1px solid var(--border-color);
  cursor: pointer;
}

.shop-item:last-of-type {
  border-bottom: none;
}

.shop-item:active {
  opacity: 0.7;
}

.shop-img {
  width: 48px;
  height: 48px;
  border-radius: var(--radius-md);
  background: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  margin-right: var(--spacing-md);
  flex-shrink: 0;
}

.shop-info {
  flex: 1;
}

.shop-title {
  font-size: var(--font-sm);
  font-weight: 500;
  color: var(--text-primary);
}

.shop-desc {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 2px;
}

.shop-tag {
  font-size: var(--font-xs);
  color: var(--primary-color);
  font-weight: 500;
}

.shop-disclaimer {
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--border-color);
  font-size: 10px;
  color: var(--text-light);
  text-align: center;
  line-height: 1.5;
}
