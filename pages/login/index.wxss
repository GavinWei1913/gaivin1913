/* 登录页样式 */
page {
  background: linear-gradient(180deg, #F0F7F4 0%, #F5F7FA 100%);
  min-height: 100vh;
}

.login-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 24px;
  min-height: 100vh;
  position: relative;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 80px;
  padding-bottom: 40px;
}

.login-logo {
  font-size: 64px;
  width: 80px;
  height: 80px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(46, 125, 91, 0.1);
  border-radius: 20px;
  margin-bottom: 16px;
}

.login-title {
  font-size: 28px;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8px;
}

.login-subtitle {
  font-size: 14px;
  color: #9999AA;
  letter-spacing: 0.5px;
}

.login-card {
  width: 100%;
  padding: 28px 24px;
  margin: 0;
}

.login-form-title {
  font-size: 20px;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 24px;
  text-align: center;
}

.form-group {
  margin-bottom: 20px;
}

.form-label {
  font-size: 13px;
  color: #666680;
  display: block;
  margin-bottom: 8px;
  font-weight: 500;
}

.input-group {
  display: flex;
  align-items: center;
  background: #F5F7FA;
  border-radius: 12px;
  padding: 0 16px;
  border: 1.5px solid #EEEEF0;
  transition: border-color 0.2s;
}

.input-group:focus-within {
  border-color: #2E7D5B;
}

.input-prefix {
  font-size: 14px;
  color: #1A1A2E;
  font-weight: 500;
  margin-right: 8px;
  padding-right: 8px;
  border-right: 1px solid #DDDDE0;
}

.form-input {
  flex: 1;
  height: 48px;
  font-size: 16px;
  color: #1A1A2E;
  background: transparent;
  border: none;
  outline: none;
}

.form-input::placeholder {
  color: #BBBBC8;
  font-size: 15px;
}

.form-input:focus {
  background: transparent;
}

.eye-icon {
  font-size: 18px;
  padding: 8px;
  color: #9999AA;
}

.btn-login {
  width: 100%;
  height: 50px;
  border-radius: 25px;
  font-size: 16px;
  font-weight: 600;
  margin-top: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 2px;
  box-shadow: 0 4px 16px rgba(46, 125, 91, 0.25);
}

.btn-disabled {
  opacity: 0.6;
}

.login-switch {
  text-align: center;
  padding: 20px 0 12px;
  font-size: 14px;
  color: #666680;
}

.link {
  color: #2E7D5B;
  font-weight: 500;
}

.login-agreement {
  text-align: center;
  font-size: 11px;
  color: #BBBBC8;
  padding-top: 4px;
}

.login-agreement .link {
  font-size: 11px;
}

.agree-hint {
  color: #BBBBC8;
}

.skip-login {
  text-align: center;
  padding: 24px;
  color: #BBBBC8;
  font-size: 14px;
}

.skip-login:active {
  color: #2E7D5B;
}

.login-footer {
  margin-top: auto;
  padding: 24px;
}

.footer-text {
  font-size: 11px;
  color: #CCC;
  letter-spacing: 0.5px;
}

.error-toast {
  position: fixed;
  top: 60px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(229, 115, 115, 0.95);
  color: #fff;
  padding: 10px 24px;
  border-radius: 20px;
  font-size: 14px;
  z-index: 999;
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
  max-width: 80%;
  text-align: center;
}

.error-toast.show {
  opacity: 1;
}
