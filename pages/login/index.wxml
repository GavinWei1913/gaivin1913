<!-- 登录/注册页面 - 支持短信验证码 -->
<view class="login-container">
  
  <!-- 顶部装饰 -->
  <view class="login-header">
    <view class="login-logo">🌿</view>
    <view class="login-title">银屑助手</view>
    <view class="login-subtitle">银屑病患者的专属康复伙伴</view>
  </view>

  <!-- ==================== 登录表单 ==================== -->
  <view class="login-card card" wx:if="{{!showRegister && !showSmsLogin}}">
    <view class="login-form-title">手机号登录</view>

    <!-- 手机号 -->
    <view class="form-group">
      <text class="form-label">手机号</text>
      <view class="input-group">
        <text class="input-prefix">+86</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" 
          value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <!-- 密码 -->
    <view class="form-group">
      <text class="form-label">密码</text>
      <view class="input-group">
        <input class="form-input" type="{{showPwd ? 'text' : 'password'}}" maxlength="20" 
          placeholder="请输入密码" value="{{password}}" bindinput="onPwdInput" />
        <text class="eye-icon" bindtap="togglePwd">{{showPwd ? '🙈' : '👁️'}}</text>
      </view>
    </view>

    <!-- 登录按钮 -->
    <view class="btn-primary btn-login" bindtap="handleLogin" wx:if="{{!loading}}">
      <text>登 录</text>
    </view>
    <view class="btn-primary btn-login btn-disabled" wx:if="{{loading}}">
      <text>登录中...</text>
    </view>

    <!-- 切换注册 -->
    <view class="login-switch" bindtap="switchMode">
      <text>没有账号？<text class="link">立即注册</text></text>
    </view>

    <!-- 短信验证码快捷登录 -->
    <view class="sms-quick-btn" bindtap="showSmsPanel">
      <text>📱 短信验证码快捷登录</text>
    </view>

    <!-- 协议 -->
    <view class="login-agreement">
      <text class="agree-hint">登录即表示同意</text>
      <text class="link">《用户协议》</text>
      <text class="agree-hint">和</text>
      <text class="link">《隐私政策》</text>
    </view>
  </view>

  <!-- ==================== 短信验证码登录/注册 ==================== -->
  <view class="login-card card" wx:if="{{showSmsLogin}}">
    <view class="login-form-title">📱 手机号验证</view>
    <view class="sms-subtitle">输入短信验证码即可快速登录或注册</view>

    <!-- 手机号 -->
    <view class="form-group">
      <text class="form-label">手机号</text>
      <view class="input-group">
        <text class="input-prefix">+86</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号"
          value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <!-- 验证码 -->
    <view class="form-group">
      <text class="form-label">验证码</text>
      <view class="input-group sms-code-group">
        <input class="form-input sms-code-input" type="number" maxlength="6" placeholder="请输入6位验证码"
          value="{{smsCode}}" bindinput="onSmsCodeInput" />
        <view class="btn-send-code {{smsCooldown > 0 ? 'btn-disabled-send' : ''}}" bindtap="sendSmsCode">
          <text wx:if="{{smsCooldown <= 0}}">获取验证码</text>
          <text wx:if="{{smsCooldown > 0}}">{{smsCooldown}}s</text>
        </view>
      </view>
    </view>

    <!-- 登录/注册按钮 -->
    <view class="btn-primary btn-login" bindtap="handleSmsLogin" wx:if="{{!loading}}">
      <text>{{isExistingUser ? '登 录' : '注册并登录'}}</text>
    </view>
    <view class="btn-primary btn-login btn-disabled" wx:if="{{loading}}">
      <text>验证中...</text>
    </view>

    <!-- 切换回密码登录 -->
    <view class="login-switch" bindtap="hideSmsPanel">
      <text>使用<text class="link">密码登录</text></text>
    </view>
  </view>

  <!-- ==================== 注册表单 ==================== -->
  <view class="login-card card" wx:if="{{showRegister && !showSmsLogin}}">
    <view class="login-form-title">注册新账号</view>
    <view class="sms-subtitle">推荐使用短信验证码注册，快速又安全</view>

    <!-- 推荐短信注册 -->
    <view class="btn-outline btn-sms-register" bindtap="showSmsPanel">
      <text>📱 短信验证码注册（推荐）</text>
    </view>

    <view class="divider-text"><text>或</text></view>

    <!-- 手机号 -->
    <view class="form-group">
      <text class="form-label">手机号</text>
      <view class="input-group">
        <text class="input-prefix">+86</text>
        <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号"
          value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <!-- 密码 -->
    <view class="form-group">
      <text class="form-label">设置密码</text>
      <view class="input-group">
        <input class="form-input" type="{{showPwd ? 'text' : 'password'}}" maxlength="20"
          placeholder="6-20位字母/数字" value="{{password}}" bindinput="onPwdInput" />
        <text class="eye-icon" bindtap="togglePwd">{{showPwd ? '🙈' : '👁️'}}</text>
      </view>
    </view>

    <!-- 确认密码 -->
    <view class="form-group">
      <text class="form-label">确认密码</text>
      <view class="input-group">
        <input class="form-input" type="{{showPwd2 ? 'text' : 'password'}}" maxlength="20"
          placeholder="再次输入密码" value="{{confirmPwd}}" bindinput="onConfirmPwdInput" />
        <text class="eye-icon" bindtap="togglePwd2">{{showPwd2 ? '🙈' : '👁️'}}</text>
      </view>
    </view>

    <!-- 注册按钮 -->
    <view class="btn-primary btn-login" bindtap="handleRegister" wx:if="{{!loading}}">
      <text>注 册</text>
    </view>
    <view class="btn-primary btn-login btn-disabled" wx:if="{{loading}}">
      <text>注册中...</text>
    </view>

    <!-- 切换登录 -->
    <view class="login-switch" bindtap="switchMode">
      <text>已有账号？<text class="link">立即登录</text></text>
    </view>
  </view>

  <!-- ===== 跳过登录（调试用） ===== -->
  <view class="skip-login" bindtap="handleSkip">
    <text>先看看 ></text>
  </view>

  <!-- ===== 错误提示 ===== -->
  <view class="error-toast {{errorMsg ? 'show' : ''}}">
    <text>{{errorMsg}}</text>
  </view>

  <!-- ===== 底部 ===== -->
  <view class="login-footer">
    <text class="footer-text">健康使用 · 信息加密存储 · 短信验证码安全护航</text>
  </view>

</view>
