/* ===== 饮食问卷样式 ===== */

.questionnaire-intro {
  margin-top: var(--spacing-xl);
  text-align: center;
  padding: var(--spacing-xl) var(--spacing-lg);
}

.intro-icon {
  font-size: 48px;
  margin-bottom: var(--spacing-lg);
}

.intro-title {
  font-size: var(--font-xl);
  font-weight: 600;
  margin-bottom: var(--spacing-md);
}

.intro-desc {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: var(--spacing-xl);
}

/* 进度 */
.progress-bar {
  height: 4px;
  background: var(--border-color);
  border-radius: 2px;
  margin: var(--spacing-lg);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: var(--primary-color);
  border-radius: 2px;
  transition: width 0.3s;
}

.progress-text {
  display: block;
  text-align: center;
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin: -8px 0 var(--spacing-md);
}

/* 问题卡片 */
.question-card {
  margin: 0 var(--spacing-lg);
}

.question-title {
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--spacing-xl);
  line-height: 1.5;
}

.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg);
  border: 1.5px solid var(--border-color);
  border-radius: var(--radius-md);
  margin-bottom: var(--spacing-sm);
  cursor: pointer;
  transition: all 0.2s;
}

.option-item.active {
  border-color: var(--primary-color);
  background: rgba(46, 125, 91, 0.04);
}

.option-label {
  font-size: var(--font-md);
  color: var(--text-primary);
  flex: 1;
}

.option-radio {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-radio.checked {
  border-color: var(--primary-color);
  background: var(--primary-color);
  box-shadow: inset 0 0 0 3px white;
}

.option-checkbox {
  width: 20px;
  height: 20px;
  border-radius: 4px;
  border: 2px solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  flex-shrink: 0;
}

.option-checkbox.checked {
  border-color: var(--primary-color);
  background: var(--primary-color);
  color: #fff;
}

/* 按钮 */
.question-actions {
  padding: var(--spacing-lg);
}

/* 结果页 */
.result-page {
  padding: var(--spacing-lg);
}

.result-card {
  margin: 0;
}

.result-icon {
  text-align: center;
  font-size: 48px;
  margin-bottom: var(--spacing-md);
}

.result-title {
  text-align: center;
  font-size: var(--font-lg);
  font-weight: 600;
  margin-bottom: var(--spacing-xl);
}

.result-section {
  margin-bottom: var(--spacing-lg);
}

.result-section-title {
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
  font-size: var(--font-md);
}

.result-section-title.green { color: var(--primary-color); }
.result-section-title.red { color: var(--danger-color); }

.result-item {
  display: flex;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-bottom: var(--spacing-xs);
  line-height: 1.5;
}

.result-bullet {
  margin-right: var(--spacing-sm);
  color: var(--primary-color);
}

.result-bullet.red {
  color: var(--danger-color);
}

.result-disclaimer {
  margin-top: var(--spacing-lg);
  padding: var(--spacing-md);
  background: rgba(179, 157, 219, 0.08);
  border-radius: var(--radius-sm);
  font-size: var(--font-xs);
  color: var(--text-light);
  line-height: 1.5;
}

.result-actions {
  padding: var(--spacing-lg) 0 var(--spacing-2xl);
}
